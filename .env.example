# Copy to .env.local and fill in values (never commit .env.local)

MONGODB_URI=mongodb://localhost:27017/taskflow
JWT_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Telegram Bot API token from BotFather
BOT_TOKEN=

# Shared secret matched against Telegram's X-Telegram-Bot-Api-Secret-Token header
# on /api/bot/webhook. Set the same value when registering the webhook.
TELEGRAM_WEBHOOK_SECRET=

# Bearer token required by /api/cron/* routes (due-reminders, daily-digest).
CRON_SECRET=
